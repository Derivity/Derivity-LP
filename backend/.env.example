OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BACKUP_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=30000
MEMORY_TTL_MS=1800000
MEMORY_MAX_TURNS=24
MEMORY_BACKEND=memory
